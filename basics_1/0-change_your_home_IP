#!/usr/bin/env bash
# Modifie /etc/hosts pour que localhost pointe sur 127.0.0.2 et facebook.com sur 8.8.8.8

# Le fichier /etc/hosts est un annuaire local sur la machine.
# Il permet de forcer la résolution d'un nom de domaine vers une IP précise,
# sans passer par un serveur DNS externe.
# Format de chaque ligne : ADRESSE_IP    NOM_DE_DOMAINE

# On écrase complètement le fichier avec nos deux entrées :
# - 127.0.0.2 localhost  → localhost pointe maintenant sur 127.0.0.2 (au lieu de 127.0.0.1)
# - 8.8.8.8 facebook.com → tout accès à facebook.com sera redirigé vers 8.8.8.8 (DNS Google)
# L'opérateur '>' redirige la sortie de echo vers le fichier (écrase le contenu existant)
echo "127.0.0.2 localhost
8.8.8.8 facebook.com" > /etc/hosts
