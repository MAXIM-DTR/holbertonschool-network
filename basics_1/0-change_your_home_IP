#!/usr/bin/env bash
# Configure les résolutions DNS de localhost et facebook.com

# Le fichier /etc/hosts permet de forcer la résolution de noms de domaine
# sans passer par un serveur DNS externe.
# C'est comme un annuaire local sur ta machine.
# Format du fichier : ADRESSE_IP    NOM_DE_DOMAINE

# 'sed' est une commande qui permet de modifier du texte dans un fichier
# -i : modifie le fichier directement (in-place)
# 's/ancien/nouveau/' : remplace 'ancien' par 'nouveau'

# On remplace l'ancienne adresse de localhost (127.0.0.1) par la nouvelle (127.0.0.2)
sed -i 's/127.0.0.1\(\s*\)localhost/127.0.0.2\1localhost/' /etc/hosts

# On vérifie si facebook.com est déjà dans le fichier /etc/hosts
# 'grep -q' cherche silencieusement (sans afficher de résultat)
if grep -q "facebook.com" /etc/hosts; then
    # Si facebook.com existe déjà, on remplace son IP actuelle par 8.8.8.8
    sed -i 's/.*facebook\.com.*/8.8.8.8\tfacebook.com/' /etc/hosts
else
    # Si facebook.com n'existe pas encore, on l'ajoute à la fin du fichier
    # 'echo' affiche du texte, '>>' l'ajoute à la fin du fichier sans effacer
    echo "8.8.8.8	facebook.com" >> /etc/hosts
fi
